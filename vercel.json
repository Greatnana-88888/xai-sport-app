{
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "/images/$1"
    },
    {
      "source": "/(.*\\.js)$",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.css)$",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.png)$",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.svg)$",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}